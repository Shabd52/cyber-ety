# Frontend Production Environment Template
# Copy this to .env.production in frontend/ folder and fill in your Render backend URL

# Backend API URL - Your Render backend service URL
NEXT_PUBLIC_API_URL=https://cyber-etymology-backend.onrender.com

# Socket.IO URL - Same as API URL (Render serves Socket.IO on same URL)
NEXT_PUBLIC_SOCKET_URL=https://cyber-etymology-backend.onrender.com

# Next.js Configuration
# These are automatically handled by Vercel, but can be overridden
# VERCEL_URL is automatically set by Vercel
# NEXT_PUBLIC_VERCEL_URL is available to frontend code
