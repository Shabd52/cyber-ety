# Backend Production Environment Template
# Copy this to .env.production in backend/ folder and fill in your Render and Neon credentials

PORT=10000
NODE_ENV=production

# PostgreSQL Database - Neon
# Get this from: https://console.neon.tech/app/projects
DATABASE_URL=postgresql://[user]:[password]@[project].neon.tech/[database]?sslmode=require

# JWT Secret - Generate a strong random string
# Command: openssl rand -base64 32
JWT_SECRET=YOUR_STRONG_RANDOM_SECRET_KEY_HERE_MIN_32_CHARS

# Socket.IO CORS - Match your Vercel frontend URL after deployment
SOCKET_CORS=https://cyber-etymology.vercel.app

# Render Configuration (automated, don't edit)
# RENDER_EXTERNAL_URL is automatically set by Render
